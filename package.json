{
  "name": "@fluxstack/config",
  "version": "1.0.1",
  "description": "Declarative configuration system for FluxStack — schema-based, type-safe, with env var mapping and validation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "fluxstack",
    "config",
    "configuration",
    "schema",
    "env",
    "environment",
    "type-safe"
  ],
  "license": "MIT"
}
